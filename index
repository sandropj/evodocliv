<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Controle de Rotina — Treino | Suplementação | Farmacologia</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:        #0d0f1a;
      --surface:   #141627;
      --surface2:  #1c1f35;
      --surface3:  #232640;
      --accent1:   #e94560;
      --accent2:   #7b5ea7;
      --accent3:   #0f9b8e;
      --accent4:   #f5a623;
      --text:      #e8eaf6;
      --text-dim:  #8892b0;
      --border:    rgba(255,255,255,0.08);
      --radius:    12px;
      --shadow:    0 4px 24px rgba(0,0,0,0.4);
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      font-size: 14px;
      line-height: 1.6;
    }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 6px; height: 6px; }
    ::-webkit-scrollbar-track { background: var(--surface); }
    ::-webkit-scrollbar-thumb { background: var(--accent2); border-radius: 3px; }

    /* ── Header ── */
    .site-header {
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      padding: 32px 24px 24px;
      text-align: center;
      border-bottom: 2px solid var(--accent1);
      position: relative;
      overflow: hidden;
    }
    .site-header::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 20% 50%, rgba(233,69,96,0.15) 0%, transparent 60%),
                  radial-gradient(ellipse at 80% 50%, rgba(123,94,167,0.15) 0%, transparent 60%);
    }
    .site-header h1 {
      font-size: clamp(20px, 4vw, 32px);
      font-weight: 800;
      letter-spacing: -0.5px;
      position: relative;
    }
    .site-header h1 span { color: var(--accent1); }
    .site-header p {
      color: var(--text-dim);
      margin-top: 8px;
      font-size: 13px;
      position: relative;
    }

    /* ── Nav Tabs ── */
    .nav-tabs {
      display: flex;
      gap: 4px;
      padding: 16px 24px 0;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      overflow-x: auto;
      flex-wrap: nowrap;
    }
    .nav-tab {
      padding: 10px 18px;
      border-radius: var(--radius) var(--radius) 0 0;
      border: none;
      cursor: pointer;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      transition: all 0.2s;
      white-space: nowrap;
      background: var(--surface2);
      color: var(--text-dim);
    }
    .nav-tab:hover { background: var(--surface3); color: var(--text); }
    .nav-tab.active {
      background: var(--accent1);
      color: #fff;
    }
    .nav-tab[data-tab="b2"].active { background: #0f3460; }
    .nav-tab[data-tab="b3"].active { background: #533483; }
    .nav-tab[data-tab="b4"].active { background: #1b4332; }
    .nav-tab[data-tab="b5"].active { background: #7b2d00; }
    .nav-tab[data-tab="b6"].active { background: #1a3a4a; }
    .nav-tab[data-tab="dash"].active { background: linear-gradient(135deg, var(--accent1), var(--accent2)); }

    /* ── Main Layout ── */
    .main { padding: 24px; max-width: 1400px; margin: 0 auto; }

    /* ── Panels ── */
    .panel { display: none; }
    .panel.active { display: block; }

    /* ── Section Card ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: var(--shadow);
    }
    .card-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }
    .card-icon {
      width: 36px; height: 36px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    .card-title { font-size: 15px; font-weight: 700; }
    .card-subtitle { font-size: 11px; color: var(--text-dim); margin-top: 2px; }

    /* ── Tables ── */
    .table-wrap { overflow-x: auto; border-radius: 8px; }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    thead th {
      padding: 10px 12px;
      text-align: center;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      border: 1px solid rgba(255,255,255,0.1);
      white-space: nowrap;
    }
    tbody td {
      padding: 9px 12px;
      border: 1px solid rgba(255,255,255,0.06);
      text-align: center;
      vertical-align: middle;
      transition: background 0.15s;
    }
    tbody tr:hover td { background: rgba(255,255,255,0.04); }
    .td-label {
      text-align: left !important;
      font-weight: 600;
      color: var(--text);
    }
    .td-empty { color: var(--text-dim); font-size: 16px; }
    .td-dose {
      background: rgba(233,69,96,0.12);
      color: #ff8fa3;
      font-weight: 600;
      border-radius: 4px;
    }
    .td-check {
      font-size: 18px;
      cursor: pointer;
      user-select: none;
      transition: transform 0.15s;
    }
    .td-check:hover { transform: scale(1.3); }
    .td-check.checked { color: #4ade80; }
    .td-check.unchecked { color: #475569; }

    /* ── Semana header ── */
    .th-dom  { background: #c0392b; }
    .th-seg  { background: #2980b9; }
    .th-ter  { background: #8e44ad; }
    .th-qua  { background: #27ae60; }
    .th-qui  { background: #e67e22; }
    .th-sex  { background: #16a085; }
    .th-sab  { background: #d35400; }

    /* ── Bloco headers ── */
    .bh-b1 { background: #16213e; }
    .bh-b2 { background: #0f3460; }
    .bh-b3 { background: #533483; }
    .bh-b4 { background: #1b4332; }
    .bh-b5 { background: #7b2d00; }
    .bh-b6 { background: #1a3a4a; }

    /* ── Badges ── */
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 20px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.5px;
    }
    .badge-im  { background: rgba(233,69,96,0.2);  color: #ff8fa3; }
    .badge-sc  { background: rgba(123,94,167,0.2); color: #c4b5fd; }
    .badge-vo  { background: rgba(15,155,142,0.2); color: #5eead4; }
    .badge-ok  { background: rgba(74,222,128,0.2); color: #4ade80; }
    .badge-off { background: rgba(100,116,139,0.2);color: #94a3b8; }

    /* ── Inputs ── */
    .input-cell {
      background: transparent;
      border: 1px solid transparent;
      color: var(--text);
      font-size: 12px;
      width: 100%;
      text-align: center;
      padding: 4px;
      border-radius: 4px;
      transition: border 0.2s, background 0.2s;
    }
    .input-cell:focus {
      outline: none;
      border-color: var(--accent1);
      background: rgba(233,69,96,0.08);
    }

    /* ── Dashboard ── */
    .dash-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
      margin-bottom: 20px;
    }
    .stat-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .stat-icon {
      width: 52px; height: 52px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 24px;
    }
    .stat-value { font-size: 28px; font-weight: 800; line-height: 1; }
    .stat-label { font-size: 11px; color: var(--text-dim); margin-top: 4px; }
    .chart-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: 16px;
    }
    .chart-card {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 20px;
    }
    .chart-card h3 { font-size: 13px; font-weight: 700; margin-bottom: 16px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.5px; }
    canvas { max-height: 260px; }

    /* ── Semana selector ── */
    .week-bar {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }
    .week-bar label { font-size: 12px; color: var(--text-dim); font-weight: 600; }
    .week-bar input[type=text] {
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 12px;
      width: 160px;
    }
    .week-bar input[type=text]:focus { outline: none; border-color: var(--accent1); }
    .btn {
      padding: 7px 16px;
      border-radius: 6px;
      border: none;
      cursor: pointer;
      font-size: 12px;
      font-weight: 600;
      transition: opacity 0.2s;
    }
    .btn:hover { opacity: 0.85; }
    .btn-primary { background: var(--accent1); color: #fff; }
    .btn-secondary { background: var(--surface3); color: var(--text); }

    /* ── Progress bar ── */
    .progress-wrap { margin-top: 8px; }
    .progress-label {
      display: flex; justify-content: space-between;
      font-size: 11px; color: var(--text-dim); margin-bottom: 4px;
    }
    .progress-bar {
      height: 6px; background: var(--surface3);
      border-radius: 3px; overflow: hidden;
    }
    .progress-fill {
      height: 100%; border-radius: 3px;
      background: linear-gradient(90deg, var(--accent1), var(--accent2));
      transition: width 0.4s ease;
    }

    /* ── Tooltip ── */
    [data-tip] { position: relative; cursor: help; }
    [data-tip]::after {
      content: attr(data-tip);
      position: absolute; bottom: 120%; left: 50%; transform: translateX(-50%);
      background: #1e293b; color: #e2e8f0;
      padding: 5px 10px; border-radius: 6px;
      font-size: 11px; white-space: nowrap;
      opacity: 0; pointer-events: none;
      transition: opacity 0.2s;
      z-index: 100;
    }
    [data-tip]:hover::after { opacity: 1; }

    /* ── Responsive ── */
    @media (max-width: 640px) {
      .main { padding: 12px; }
      .nav-tabs { padding: 12px 12px 0; }
      .nav-tab { padding: 8px 12px; font-size: 10px; }
    }

    /* ── Print ── */
    @media print {
      .nav-tabs, .week-bar, .btn { display: none; }
      .panel { display: block !important; }
      body { background: #fff; color: #000; }
      .card { box-shadow: none; border: 1px solid #ccc; }
    }
  </style>
</head>
<body>

<!-- ══ HEADER ══════════════════════════════════════════════════════════════ -->
<header class="site-header">
  <h1>🏋️ Controle de Rotina — <span>Treino</span> | Suplementação | Farmacologia</h1>
  <p>Planilha interativa de acompanhamento semanal · Clique nas células para editar · Checkboxes clicáveis</p>
</header>

<!-- ══ NAV TABS ════════════════════════════════════════════════════════════ -->
<nav class="nav-tabs" id="navTabs">
  <button class="nav-tab active" data-tab="dash">📊 Dashboard</button>
  <button class="nav-tab" data-tab="b1">📅 Cabeçalho Semanal</button>
  <button class="nav-tab" data-tab="b2">💉 Rotina Semanal</button>
  <button class="nav-tab" data-tab="b3">⚗️ Ergogênicos</button>
  <button class="nav-tab" data-tab="b4">✅ Rotina Diária</button>
  <button class="nav-tab" data-tab="b5">📈 Respostas / Efeitos</button>
  <button class="nav-tab" data-tab="b6">💊 Manipulados</button>
</nav>

<!-- ══ MAIN ════════════════════════════════════════════════════════════════ -->
<main class="main">

  <!-- ── DASHBOARD ────────────────────────────────────────────────────────── -->
  <section class="panel active" id="panel-dash">
    <div class="week-bar">
      <label>Semana:</label>
      <input type="text" id="weekLabel" value="Semana 1 — 03/03 a 09/03/2026" />
      <button class="btn btn-primary" onclick="salvarDados()">💾 Salvar Dados</button>
      <button class="btn btn-secondary" onclick="window.print()">🖨️ Imprimir</button>
    </div>

    <div class="dash-grid">
      <div class="stat-card">
        <div class="stat-icon" style="background:rgba(233,69,96,0.15)">💉</div>
        <div>
          <div class="stat-value" style="color:var(--accent1)" id="stat-aplicacoes">7</div>
          <div class="stat-label">Aplicações na semana</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:rgba(123,94,167,0.15)">✅</div>
        <div>
          <div class="stat-value" style="color:#c4b5fd" id="stat-checklist">0%</div>
          <div class="stat-label">Checklist diário concluído</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:rgba(15,155,142,0.15)">⚗️</div>
        <div>
          <div class="stat-value" style="color:#5eead4">6</div>
          <div class="stat-label">Compostos ativos</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background:rgba(245,166,35,0.15)">💊</div>
        <div>
          <div class="stat-value" style="color:var(--accent4)" id="stat-manipulados">0%</div>
          <div class="stat-label">Manipulados tomados</div>
        </div>
      </div>
    </div>

    <div class="chart-grid">
      <div class="chart-card">
        <h3>📅 Aplicações por Dia da Semana</h3>
        <canvas id="chartAplicacoes"></canvas>
      </div>
      <div class="chart-card">
        <h3>⚗️ Compostos Ergogênicos</h3>
        <canvas id="chartErgogenicos"></canvas>
      </div>
      <div class="chart-card">
        <h3>📈 Progresso do Checklist Diário</h3>
        <canvas id="chartChecklist"></canvas>
      </div>
      <div class="chart-card">
        <h3>💊 Distribuição de Suplementos</h3>
        <canvas id="chartSuple"></canvas>
      </div>
    </div>
  </section>

  <!-- ── BLOCO 1 ───────────────────────────────────────────────────────────── -->
  <section class="panel" id="panel-b1">
    <div class="card">
      <div class="card-header">
        <div class="card-icon bh-b1" style="color:#fff">📅</div>
        <div>
          <div class="card-title">BLOCO 1 — CABEÇALHO SEMANAL</div>
          <div class="card-subtitle">Identificação e período da semana de treino</div>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th class="bh-b1" style="text-align:left">SEMANA / PERÍODO</th>
              <th class="th-dom">DOM</th>
              <th class="th-seg">SEG</th>
              <th class="th-ter">TER</th>
              <th class="th-qua">QUA</th>
              <th class="th-qui">QUI</th>
              <th class="th-sex">SEX</th>
              <th class="th-sab">SÁB</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="td-label">Nº da Semana</td>
              <td colspan="7"><input class="input-cell" placeholder="Ex: Semana 1 — Ciclo 1" /></td>
            </tr>
            <tr>
              <td class="td-label">Data (início / fim)</td>
              <td colspan="7"><input class="input-cell" placeholder="Ex: 03/03/2026 a 09/03/2026" /></td>
            </tr>
            <tr>
              <td class="td-label">Fase do Ciclo</td>
              <td colspan="7"><input class="input-cell" placeholder="Ex: Bulk / Cutting / Manutenção" /></td>
            </tr>
            <tr>
              <td class="td-label">Objetivo da Semana</td>
              <td colspan="7"><input class="input-cell" placeholder="Ex: Foco em hipertrofia — volume alto" /></td>
            </tr>
            <tr>
              <td class="td-label">Observações Gerais</td>
              <td colspan="7"><input class="input-cell" placeholder="Anotações livres..." /></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── BLOCO 2 ───────────────────────────────────────────────────────────── -->
  <section class="panel" id="panel-b2">
    <div class="card">
      <div class="card-header">
        <div class="card-icon bh-b2" style="color:#fff">💉</div>
        <div>
          <div class="card-title">BLOCO 2 — ROTINA SEMANAL DE APLICAÇÕES</div>
          <div class="card-subtitle">Registre doses e aplicações por dia da semana</div>
        </div>
      </div>
      <div class="table-wrap">
        <table id="tabelaRotina">
          <thead>
            <tr>
              <th class="bh-b2" style="text-align:left;min-width:180px">COMPOSTO / PROTOCOLO</th>
              <th class="th-dom">DOM</th>
              <th class="th-seg">SEG</th>
              <th class="th-ter">TER</th>
              <th class="th-qua">QUA</th>
              <th class="th-qui">QUI</th>
              <th class="th-sex">SEX</th>
              <th class="th-sab">SÁB</th>
            </tr>
          </thead>
          <tbody id="bodyRotina">
            <!-- gerado por JS -->
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── BLOCO 3 ───────────────────────────────────────────────────────────── -->
  <section class="panel" id="panel-b3">
    <div class="card">
      <div class="card-header">
        <div class="card-icon bh-b3" style="color:#fff">⚗️</div>
        <div>
          <div class="card-title">BLOCO 3 — ERGOGÊNICOS UTILIZADOS</div>
          <div class="card-subtitle">Compostos, doses, via de administração e status</div>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th class="bh-b3" style="text-align:left">COMPOSTO</th>
              <th class="bh-b3">DOSE SEMANAL</th>
              <th class="bh-b3">VIA</th>
              <th class="bh-b3">FREQUÊNCIA</th>
              <th class="bh-b3">INÍCIO</th>
              <th class="bh-b3">DURAÇÃO</th>
              <th class="bh-b3">OBSERVAÇÕES</th>
              <th class="bh-b3">STATUS</th>
            </tr>
          </thead>
          <tbody id="bodyErgo">
            <!-- gerado por JS -->
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── BLOCO 4 ───────────────────────────────────────────────────────────── -->
  <section class="panel" id="panel-b4">
    <div class="card">
      <div class="card-header">
        <div class="card-icon bh-b4" style="color:#fff">✅</div>
        <div>
          <div class="card-title">BLOCO 4 — ROTINA DIÁRIA (CHECKLIST)</div>
          <div class="card-subtitle">Marque cada item conforme executado no dia</div>
        </div>
      </div>
      <div class="progress-wrap" style="margin-bottom:16px">
        <div class="progress-label">
          <span>Progresso semanal do checklist</span>
          <span id="checkPct">0%</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" id="checkBar" style="width:0%"></div></div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th class="bh-b4" style="text-align:left;min-width:140px">MOMENTO</th>
              <th class="bh-b4" style="text-align:left;min-width:180px">ITEM</th>
              <th class="th-dom">DOM</th>
              <th class="th-seg">SEG</th>
              <th class="th-ter">TER</th>
              <th class="th-qua">QUA</th>
              <th class="th-qui">QUI</th>
              <th class="th-sex">SEX</th>
              <th class="th-sab">SÁB</th>
            </tr>
          </thead>
          <tbody id="bodyChecklist">
            <!-- gerado por JS -->
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ── BLOCO 5 ───────────────────────────────────────────────────────────── -->
  <section class="panel" id="panel-b5">
    <div class="card">
      <div class="card-header">
        <div class="card-icon bh-b5" style="color:#fff">📈</div>
        <div>
          <div class="card-title">BLOCO 5 — CONTROLE DE RESPOSTAS / EFEITOS</div>
          <div class="card-subtitle">Monitoramento semanal de biometria e efeitos</div>
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th class="bh-b5">DATA</th>
              <th class="bh-b5">SEMANA</th>
              <th class="bh-b5">PESO (kg)</th>
              <th class="bh-b5">GORDURA (%)</th>
              <th class="bh-b5">DISPOSIÇÃO (1-10)</th>
              <th class="bh-b5">LIBIDO (1-10)</th>
              <th class="bh-b5">EFEITOS ADVERSOS</th>
              <th class="bh-b5">OBSERVAÇÕES GERAIS</th>
            </tr>
          </thead>
          <tbody id="bodyEfeitos">
            <!-- gerado por JS -->
          </tbody>
        </table>
      </div>
    </div>

    <div class="card" style="margin-top:20px">
      <div class="card-header">
        <div class="card-icon bh-b5" style="color:#fff">📊</div>
        <div>
          <div class="card-title">Gráfico de Evolução</div>
          <div class="card-subtitle">Peso e disposição ao longo das semanas</div>
        </div>
      </div>
      <canvas id="chartEvolucao" style="max-height:280px"></canvas>
    </div>
  </section>

  <!-- ── BLOCO 6 ───────────────────────────────────────────────────────────── -->
  <section class="panel" id="panel-b6">
    <div class="card">
      <div class="card-header">
        <div class="card-icon bh-b6" style="color:#fff">💊</div>
        <div>
          <div class="card-title">BLOCO 6 — ROTINA DE MANIPULADOS</div>
          <div class="card-subtitle">Controle semanal de suplementos manipulados</div>
        </div>
      </div>
      <div class="progress-wrap" style="margin-bottom:16px">
        <div class="progress-label">
          <span>Adesão semanal aos manipulados</span>
          <span id="manipPct">0%</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" id="manipBar" style="width:0%;background:linear-gradient(90deg,#1a3a4a,#0f9b8e)"></div></div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th class="bh-b6" style="text-align:left;min-width:200px">MANIPULADO / MOMENTO</th>
              <th class="th-dom">DOM</th>
              <th class="th-seg">SEG</th>
              <th class="th-ter">TER</th>
              <th class="th-qua">QUA</th>
              <th class="th-qui">QUI</th>
              <th class="th-sex">SEX</th>
              <th class="th-sab">SÁB</th>
            </tr>
          </thead>
          <tbody id="bodyManipulados">
            <!-- gerado por JS -->
          </tbody>
        </table>
      </div>
    </div>
  </section>

</main>

<!-- ══ SCRIPTS ═════════════════════════════════════════════════════════════ -->
<script>
// ── Dados base ──────────────────────────────────────────────────────────────
const DIAS_ABREV = ["DOM","SEG","TER","QUA","QUI","SEX","SÁB"];

const rotinaData = [
  { nome:"Test Enantato",              doses:["1 mL","—","1 mL","—","—","—","—"] },
  { nome:"Tren Acetato",               doses:["—","1 mL","—","1 mL","—","—","—"] },
  { nome:"Tirzepatida",                doses:["0,5 mg","—","—","—","—","—","—"] },
  { nome:"Nandrolona Decanoato",       doses:["—","—","—","—","—","—","—"] },
  { nome:"Primobolan (Metenolona)",    doses:["—","—","—","—","—","—","—"] },
  { nome:"Clembuterol",                doses:["—","—","—","—","—","—","—"] },
  { nome:"Propionato de Testosterona", doses:["—","—","—","—","—","—","—"] },
  { nome:"Outro composto",             doses:["—","—","—","—","—","—","—"] },
];

const ergoData = [
  { nome:"Enantato de Testosterona",    dose:"",via:"IM",freq:"",inicio:"",dur:"",obs:"",status:"Ativo" },
  { nome:"Nandrolona Decanoato",        dose:"",via:"IM",freq:"",inicio:"",dur:"",obs:"",status:"Ativo" },
  { nome:"Primobolan (Metenolona)",     dose:"",via:"IM",freq:"",inicio:"",dur:"",obs:"",status:"Ativo" },
  { nome:"Clembuterol",                 dose:"",via:"VO",freq:"",inicio:"",dur:"",obs:"",status:"Ativo" },
  { nome:"Propionato de Testosterona",  dose:"",via:"IM",freq:"",inicio:"",dur:"",obs:"",status:"Ativo" },
  { nome:"Tirzepatida",                 dose:"",via:"SC",freq:"",inicio:"",dur:"",obs:"",status:"Ativo" },
];

const checklistData = [
  { momento:"PRÉ-TREINO",    item:"Clembuterol" },
  { momento:"",              item:"Cafeína / Pré-treino" },
  { momento:"TREINO",        item:"Hidratação / Intra-treino" },
  { momento:"PÓS-TREINO",   item:"Whey Protein" },
  { momento:"",              item:"Creatina" },
  { momento:"CAFÉ DA MANHÃ",item:"Omega 3" },
  { momento:"",              item:"CoQ10" },
  { momento:"",              item:"Vitamina D" },
  { momento:"ALMOÇO",        item:"Omega 3" },
  { momento:"",              item:"Proteína sólida" },
  { momento:"LANCHE",        item:"Proteína / Fruta" },
  { momento:"JANTA",         item:"Omega 3" },
  { momento:"",              item:"Rosuvastatina" },
  { momento:"",              item:"Magnésio" },
];

const manipuladosData = [
  "OMEGA 3 — MANHÃ",
  "OMEGA 3 — ALMOÇO",
  "OMEGA 3 — NOITE",
  "CoQ10 — MANHÃ",
  "INTERVENÇÃO 1",
  "INTERVENÇÃO 2",
  "INTERVENÇÃO 3",
];

// ── Estado de checkboxes ─────────────────────────────────────────────────────
let checkState = {};
let manipState = {};

function toggleCheck(id, container) {
  const store = container === 'check' ? checkState : manipState;
  store[id] = !store[id];
  const el = document.getElementById(id);
  if (el) {
    el.textContent = store[id] ? "✅" : "☐";
    el.classList.toggle("checked", store[id]);
    el.classList.toggle("unchecked", !store[id]);
  }
  updateProgress();
}

function updateProgress() {
  // Checklist
  const checkKeys = Object.keys(checkState);
  const checkDone = checkKeys.filter(k => checkState[k]).length;
  const checkTotal = checklistData.length * 7;
  const checkPct = checkTotal > 0 ? Math.round((checkDone / checkTotal) * 100) : 0;
  document.getElementById("checkPct").textContent = checkPct + "%";
  document.getElementById("checkBar").style.width = checkPct + "%";
  document.getElementById("stat-checklist").textContent = checkPct + "%";

  // Manipulados
  const manipKeys = Object.keys(manipState);
  const manipDone = manipKeys.filter(k => manipState[k]).length;
  const manipTotal = manipuladosData.length * 7;
  const manipPct = manipTotal > 0 ? Math.round((manipDone / manipTotal) * 100) : 0;
  document.getElementById("manipPct").textContent = manipPct + "%";
  document.getElementById("manipBar").style.width = manipPct + "%";
  document.getElementById("stat-manipulados").textContent = manipPct + "%";

  // Atualizar gráfico checklist
  if (window.chartChecklistInst) {
    const byDay = DIAS_ABREV.map((_, di) => {
      return checklistData.filter((_, ri) => checkState[`ck_${ri}_${di}`]).length;
    });
    window.chartChecklistInst.data.datasets[0].data = byDay;
    window.chartChecklistInst.update();
  }
}

// ── Render Bloco 2 ───────────────────────────────────────────────────────────
function renderRotina() {
  const tbody = document.getElementById("bodyRotina");
  tbody.innerHTML = "";
  rotinaData.forEach((row, ri) => {
    const tr = document.createElement("tr");
    const tdLabel = document.createElement("td");
    tdLabel.className = "td-label";
    tdLabel.innerHTML = `<input class="input-cell" style="text-align:left;font-weight:600" value="${row.nome}" />`;
    tr.appendChild(tdLabel);
    row.doses.forEach((dose, di) => {
      const td = document.createElement("td");
      const isDose = dose !== "—";
      td.className = isDose ? "td-dose" : "td-empty";
      td.innerHTML = `<input class="input-cell" value="${dose}" style="${isDose ? 'color:#ff8fa3;font-weight:700' : 'color:#475569'}" />`;
      tr.appendChild(td);
    });
    tbody.appendChild(tr);
  });
}

// ── Render Bloco 3 ───────────────────────────────────────────────────────────
function renderErgo() {
  const tbody = document.getElementById("bodyErgo");
  tbody.innerHTML = "";
  ergoData.forEach((row, ri) => {
    const tr = document.createElement("tr");
    const viaBadge = {IM:"badge-im",SC:"badge-sc",VO:"badge-vo"}[row.via] || "badge-off";
    tr.innerHTML = `
      <td class="td-label"><input class="input-cell" style="text-align:left;font-weight:600;color:#c4b5fd" value="${row.nome}" /></td>
      <td><input class="input-cell" value="${row.dose}" placeholder="Ex: 500mg" /></td>
      <td><span class="badge ${viaBadge}">${row.via}</span></td>
      <td><input class="input-cell" value="${row.freq}" placeholder="Ex: 2x/sem" /></td>
      <td><input class="input-cell" value="${row.inicio}" placeholder="dd/mm" /></td>
      <td><input class="input-cell" value="${row.dur}" placeholder="Ex: 12 sem" /></td>
      <td><input class="input-cell" value="${row.obs}" placeholder="Observações..." /></td>
      <td><span class="badge badge-ok">${row.status}</span></td>
    `;
    tbody.appendChild(tr);
  });
}

// ── Render Bloco 4 ───────────────────────────────────────────────────────────
function renderChecklist() {
  const tbody = document.getElementById("bodyChecklist");
  tbody.innerHTML = "";
  checklistData.forEach((row, ri) => {
    const tr = document.createElement("tr");
    const isMomento = row.momento !== "";
    const bgStyle = isMomento ? "background:rgba(27,67,50,0.3)" : "";
    tr.style.cssText = bgStyle;
    let cells = `
      <td class="td-label" style="color:${isMomento ? '#86efac' : '#94a3b8'};font-weight:${isMomento ? '700' : '400'}">${row.momento}</td>
      <td style="text-align:left;color:#e2e8f0">${row.item}</td>
    `;
    DIAS_ABREV.forEach((_, di) => {
      const id = `ck_${ri}_${di}`;
      checkState[id] = checkState[id] || false;
      cells += `<td class="td-check unchecked" id="${id}" onclick="toggleCheck('${id}','check')">☐</td>`;
    });
    tr.innerHTML = cells;
    tbody.appendChild(tr);
  });
}

// ── Render Bloco 5 ───────────────────────────────────────────────────────────
function renderEfeitos() {
  const tbody = document.getElementById("bodyEfeitos");
  tbody.innerHTML = "";
  for (let i = 0; i < 8; i++) {
    const tr = document.createElement("tr");
    tr.innerHTML = `
      <td><input class="input-cell" placeholder="dd/mm/aaaa" /></td>
      <td><input class="input-cell" placeholder="Sem. ${i+1}" /></td>
      <td><input class="input-cell" placeholder="kg" /></td>
      <td><input class="input-cell" placeholder="%" /></td>
      <td><input class="input-cell" placeholder="1-10" /></td>
      <td><input class="input-cell" placeholder="1-10" /></td>
      <td><input class="input-cell" placeholder="Descreva..." /></td>
      <td><input class="input-cell" placeholder="Anotações..." /></td>
    `;
    tbody.appendChild(tr);
  }
}

// ── Render Bloco 6 ───────────────────────────────────────────────────────────
function renderManipulados() {
  const tbody = document.getElementById("bodyManipulados");
  tbody.innerHTML = "";
  manipuladosData.forEach((nome, ri) => {
    const tr = document.createElement("tr");
    let cells = `<td class="td-label" style="color:#93c5fd">${nome}</td>`;
    DIAS_ABREV.forEach((_, di) => {
      const id = `mp_${ri}_${di}`;
      manipState[id] = manipState[id] || false;
      cells += `<td class="td-check unchecked" id="${id}" onclick="toggleCheck('${id}','manip')">☐</td>`;
    });
    tr.innerHTML = cells;
    tbody.appendChild(tr);
  });
}

// ── Charts ───────────────────────────────────────────────────────────────────
function initCharts() {
  Chart.defaults.color = "#8892b0";
  Chart.defaults.borderColor = "rgba(255,255,255,0.06)";

  // Chart 1 — Aplicações por dia
  const aplicacoesPorDia = DIAS_ABREV.map((_, di) =>
    rotinaData.reduce((acc, row) => acc + (row.doses[di] !== "—" ? 1 : 0), 0)
  );
  new Chart(document.getElementById("chartAplicacoes"), {
    type: "bar",
    data: {
      labels: DIAS_ABREV,
      datasets: [{
        label: "Aplicações",
        data: aplicacoesPorDia,
        backgroundColor: ["#c0392b","#2980b9","#8e44ad","#27ae60","#e67e22","#16a085","#d35400"],
        borderRadius: 6,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, ticks: { stepSize: 1 } }
      }
    }
  });

  // Chart 2 — Ergogênicos (donut)
  new Chart(document.getElementById("chartErgogenicos"), {
    type: "doughnut",
    data: {
      labels: ergoData.map(e => e.nome.split(" ")[0]),
      datasets: [{
        data: [1,1,1,1,1,1],
        backgroundColor: ["#e94560","#7b5ea7","#0f9b8e","#f5a623","#3b82f6","#ec4899"],
        borderWidth: 2,
        borderColor: "#141627",
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: "right", labels: { font: { size: 10 }, boxWidth: 12 } }
      },
      cutout: "65%",
    }
  });

  // Chart 3 — Checklist por dia (bar)
  window.chartChecklistInst = new Chart(document.getElementById("chartChecklist"), {
    type: "bar",
    data: {
      labels: DIAS_ABREV,
      datasets: [{
        label: "Itens concluídos",
        data: [0,0,0,0,0,0,0],
        backgroundColor: "rgba(74,222,128,0.6)",
        borderColor: "#4ade80",
        borderWidth: 1,
        borderRadius: 6,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, max: checklistData.length, ticks: { stepSize: 2 } }
      }
    }
  });

  // Chart 4 — Suplementos (pie)
  new Chart(document.getElementById("chartSuple"), {
    type: "pie",
    data: {
      labels: ["Omega 3","CoQ10","Whey Protein","Rosuvastatina","Magnésio","Vitamina D"],
      datasets: [{
        data: [3,1,1,1,1,1],
        backgroundColor: ["#0f9b8e","#f5a623","#e94560","#7b5ea7","#3b82f6","#ec4899"],
        borderWidth: 2,
        borderColor: "#141627",
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: "right", labels: { font: { size: 10 }, boxWidth: 12 } }
      }
    }
  });

  // Chart 5 — Evolução (bloco 5)
  new Chart(document.getElementById("chartEvolucao"), {
    type: "line",
    data: {
      labels: ["Sem 1","Sem 2","Sem 3","Sem 4","Sem 5","Sem 6","Sem 7","Sem 8"],
      datasets: [
        {
          label: "Peso (kg)",
          data: [null,null,null,null,null,null,null,null],
          borderColor: "#e94560",
          backgroundColor: "rgba(233,69,96,0.1)",
          tension: 0.4,
          fill: true,
          yAxisID: "y",
        },
        {
          label: "Disposição (1-10)",
          data: [null,null,null,null,null,null,null,null],
          borderColor: "#4ade80",
          backgroundColor: "rgba(74,222,128,0.1)",
          tension: 0.4,
          fill: true,
          yAxisID: "y1",
        }
      ]
    },
    options: {
      responsive: true,
      interaction: { mode: "index", intersect: false },
      plugins: { legend: { position: "top" } },
      scales: {
        y:  { type:"linear", display:true, position:"left",  title:{ display:true, text:"Peso (kg)" } },
        y1: { type:"linear", display:true, position:"right", title:{ display:true, text:"Disposição" }, grid:{ drawOnChartArea:false } }
      }
    }
  });
}

// ── Tabs ─────────────────────────────────────────────────────────────────────
document.querySelectorAll(".nav-tab").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".nav-tab").forEach(b => b.classList.remove("active"));
    document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
    btn.classList.add("active");
    document.getElementById("panel-" + btn.dataset.tab).classList.add("active");
  });
});

// ── Salvar (localStorage) ────────────────────────────────────────────────────
function salvarDados() {
  localStorage.setItem("checkState", JSON.stringify(checkState));
  localStorage.setItem("manipState", JSON.stringify(manipState));
  localStorage.setItem("weekLabel", document.getElementById("weekLabel").value);
  alert("✅ Dados salvos localmente no navegador!");
}

function carregarDados() {
  const cs = localStorage.getItem("checkState");
  const ms = localStorage.getItem("manipState");
  const wl = localStorage.getItem("weekLabel");
  if (cs) checkState = JSON.parse(cs);
  if (ms) manipState = JSON.parse(ms);
  if (wl) document.getElementById("weekLabel").value = wl;
}

// ── Init ─────────────────────────────────────────────────────────────────────
carregarDados();
renderRotina();
renderErgo();
renderChecklist();
renderEfeitos();
renderManipulados();
initCharts();
updateProgress();

// Reaplica estados salvos nos checkboxes
Object.keys(checkState).forEach(id => {
  if (checkState[id]) {
    const el = document.getElementById(id);
    if (el) { el.textContent = "✅"; el.classList.add("checked"); el.classList.remove("unchecked"); }
  }
});
Object.keys(manipState).forEach(id => {
  if (manipState[id]) {
    const el = document.getElementById(id);
    if (el) { el.textContent = "✅"; el.classList.add("checked"); el.classList.remove("unchecked"); }
  }
});
</script>
</body>
</html>
